# VisualVoice — Environment Variables Template
# ─────────────────────────────────────────────
# 1. Copy this file to .env  →  cp .env.example .env
# 2. Fill in your real API keys (never commit .env to git!)
# 3. The app reads these automatically via python-dotenv

# ── HuggingFace ────────────────────────────────────────────────────────
# Get your token at: https://huggingface.co/settings/tokens
# Required for: BLIP image captioning + TTS Inference API
HUGGINGFACE_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Grok (xAI) ─────────────────────────────────────────────────────────
# Get your key at: https://console.x.ai/
GROK_API_KEY=xai_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Groq (Ultra-Fast Llama 3.3) ──────────────────────────────────────────
# Get your key at: https://console.groq.com/
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional: Logging ───────────────────────────────────────────────────
# Set to DEBUG for verbose output, INFO for production (default: INFO)
LOG_LEVEL=INFO
